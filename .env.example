# Copy to .env.local and fill in real values.

# Payload CMS — any high-entropy string. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# PostgreSQL — local Docker by default. Bring your own connection string for hosted DBs.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/claude_ai_mcp_demo

# MCP server kill switch. Set to 'true' to expose /api/mcp; anything else and
# the plugin registers nothing.
MCP_ENABLED=true

# WorkOS AuthKit — OAuth authorization server for connecting the MCP server to
# Claude.ai web (which requires an OAuth flow, not a pasted key). The MCP server
# is the resource server: it advertises protected-resource metadata and
# validates AuthKit-issued JWTs (issuer + JWKS under the AuthKit domain;
# audience = the MCP server URL). Register that URL as a Resource Indicator in
# the WorkOS Dashboard.
WORKOS_CLIENT_ID=client_...
WORKOS_API_KEY=sk_...
WORKOS_AUTHKIT_DOMAIN=https://your-project.authkit.app

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000