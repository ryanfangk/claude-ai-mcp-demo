# Committed, NON-SECRET test environment. Loaded by vitest.config.mts before
# anything imports payload.config (which requireEnv()s these at module load).
#
# DATABASE_URL points to a DISPOSABLE test DB whose name MUST contain "test"
# (guarded by tests/int/globalSetup.ts so the destructive drop+create routine
# can never hit dev/prod). The Docker compose service is what serves it on
# :5432 — same host/port/credentials as the dev DB, different database name.

PAYLOAD_SECRET=ci-placeholder-secret-for-tests-only
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/claude_ai_mcp_demo_test

# Disable Payload's dev schema-push so the migration files are authoritative
# in tests (push would race the migrations the globalSetup applies).
DISABLE_DB_PUSH=true

# Deterministic email domain — the deriveAgentEmail helper reads this. Set so
# assertions on derived agent emails don't depend on shell env.
MCP_AGENT_EMAIL_DOMAIN=agents.local
